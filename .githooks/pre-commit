#!/usr/bin/env bash
# Auto-format staged Rust with rustfmt before each commit, so commits always
# satisfy the `fmt --check` CI gate (see .github/workflows/ci.yml).
#
# Enable in your clone with: `just install-hooks` (sets core.hooksPath).
# Exits fast when no Rust files are staged.
set -euo pipefail

staged_rs=$(git diff --cached --name-only --diff-filter=ACM -- '*.rs')
[ -z "$staged_rs" ] && exit 0

if ! command -v cargo >/dev/null 2>&1; then
  echo "pre-commit: cargo not found; skipping rustfmt (CI still enforces it)" >&2
  exit 0
fi

# rustfmt needs the whole workspace for module/macro context.
cargo fmt --all

# Re-stage the formatted versions of the files that were already staged.
echo "$staged_rs" | xargs git add --
